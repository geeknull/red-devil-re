{
  "name": "red-devil-re",
  "version": "0.0.0",
  "private": true,
  "description": "红魔特种兵 1 & 2 — J2ME 游戏 100% 原汁原味复刻 (TS + Canvas)",
  "type": "module",
  "scripts": {
    "verify:rng": "node --experimental-strip-types packages/j2me-shim/test/random.verify.ts",
    "test:shim": "node --experimental-strip-types packages/j2me-shim/test/run-all.ts",
    "dev": "pnpm --filter @red-devil/web dev",
    "test:behavior": "node --experimental-transform-types packages/behavior-net/run.ts",
    "bless:behavior": "node --experimental-transform-types packages/behavior-net/bless.ts",
    "oracle:diff": "packages/jvm-oracle/diff.sh",
    "oracle:run": "packages/jvm-oracle/run.sh"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3"
  }
}
